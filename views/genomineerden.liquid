{% render 'partials/head.liquid', title: 'Genomineerden' %}

<a class="skip-link" href="#inhoud">Ga direct naar de inhoud</a>

{% render 'partials/nav.liquid' %}

<main class="pagina-container" id="inhoud">
  <section class="pagina-intro">
    <header class="divider">
      <h1>Genomineerde studenten</h1>
    </header>

    <p>Klik op een genomineerde student om meer te bekijken.</p>
  </section>

  <section class="genomineerden-sectie">
    <header class="divider">
      <h2>Genomineerden</h2>
    </header>

    {% if nominees and nominees.size > 0 %}
      <ul class="genomineerden-grid">
        {% for student in nominees %}
          {% if student.title and student.title != blank %}
            <li>
              <div class="genomineerde-kaart">
                <figure class="kaart-afbeelding">
                  {% if student.profile_picture %}
                    <picture>
                      <source
                        type="image/avif"
                        srcset="https://fdnd-agency.directus.app/assets/{{ student.profile_picture }}?format=avif">

                      <source
                        type="image/webp"
                        srcset="https://fdnd-agency.directus.app/assets/{{ student.profile_picture }}?format=webp">

                      <img
                        src="https://fdnd-agency.directus.app/assets/{{ student.profile_picture }}"
                        alt="Profielfoto van {{ student.title }}"
                        width="220"
                        height="220"
                        loading="lazy">
                    </picture>
                  {% else %}
                    <img
                      src="/style/assets/fotothijs.jpg"
                      alt="Profielfoto van {{ student.title }}"
                      width="220"
                      height="220"
                      loading="lazy">
                  {% endif %}
                </figure>

                <section class="kaart-inhoud">
                  <h3>{{ student.title }}</h3>

                  {% if student.institution %}
                    <p>{{ student.institution }}</p>
                  {% endif %}

                  {% if student.course %}
                    <p>{{ student.course }}</p>
                  {% endif %}

                  <p>
                    <a class="tekst-link" href="/genomineerden/{{ student.id }}">
                      Lees meer over {{ student.title }}
                    </a>
                  </p>
                </section>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% else %}
      <p>Er zijn nog geen genomineerden.</p>
    {% endif %}
  </section>
</main>

{% render 'partials/foot.liquid' %}