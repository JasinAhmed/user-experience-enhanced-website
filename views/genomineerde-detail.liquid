{% render 'partials/head.liquid', title: nominee.title %}

<a class="skip-link" href="#inhoud">Ga direct naar de inhoud</a>

{% render 'partials/nav.liquid' %}

<main class="pagina-container" id="inhoud">
  <p class="pagina-intro">
    <a class="tekst-link" href="/genomineerden">← Terug naar overzicht</a>
  </p>

  <article class="genomineerde-detail-kaart">
    <figure class="detail-afbeelding">

      {% if nominee.profile_picture %}
        <!-- 🔥 DIRECTUS IMAGE -->
        <picture>

          <!-- AVIF -->
          <source
            type="image/avif"
            srcset="https://fdnd-agency.directus.app/assets/{{ nominee.profile_picture }}?format=avif">

          <!-- WebP -->
          <source
            type="image/webp"
            srcset="https://fdnd-agency.directus.app/assets/{{ nominee.profile_picture }}?format=webp">

          <!-- Fallback -->
          <img
            src="https://fdnd-agency.directus.app/assets/{{ nominee.profile_picture }}"
            alt="Profielfoto van {{ nominee.title }}"
            width="500"
            height="500"
            loading="lazy">

        </picture>

      {% else %}
        <!-- 🔹 LOKALE FALLBACK -->
        <img
          src="/style/assets/fotothijs.jpg"
          alt="Profielfoto van {{ nominee.title }}"
          width="500"
          height="500"
          loading="lazy">
      {% endif %}

    </figure>

    <section class="detail-inhoud">
      <h1>{{ nominee.title }}</h1>

      {% if nominee.institution %}
        <p><strong>Onderwijsinstelling:</strong> {{ nominee.institution }}</p>
      {% endif %}

      {% if nominee.course %}
        <p><strong>Opleiding:</strong> {{ nominee.course }}</p>
      {% endif %}

      {% if nominee.education_variant %}
        <p><strong>Variant:</strong> {{ nominee.education_variant }}</p>
      {% endif %}

      {% if nominee.previous_course %}
        <p><strong>Vorige opleiding:</strong> {{ nominee.previous_course }}</p>
      {% endif %}

      {% if nominee.header %}
        <p><strong>Categorie:</strong> {{ nominee.header }}</p>
      {% endif %}

      {% if nominee.date %}
        <p><strong>Datum:</strong> {{ nominee.date | date: "%-d %B %Y" }}</p>
      {% endif %}

      {% if nominee.excerpt %}
        <section>
          <h2>Korte introductie</h2>
          {{ nominee.excerpt }}
        </section>
      {% endif %}

      {% if nominee.body %}
        <section>
          <h2>Meer over deze genomineerde</h2>
          {{ nominee.body }}
        </section>
      {% endif %}

      <section class="extra-aanbevelingen">
        <h2>Aanbevelingen</h2>

        <section>
          <h3>Nominatie Hogeschool</h3>
          <p>Thijs is een student op wie wij enorm trots zijn...</p>
          <p>In samenwerking met medestudenten...</p>
          <p>Zijn integriteit is hierin opvallend...</p>
          <p>Deze houding is van grote waarde...</p>
          <p>Wat Thijs daarnaast onderscheidt...</p>
          <p>Dat maakt hem in onze ogen...</p>
          <p><strong>Fransien Hummel</strong></p>
        </section>

        <section>
          <h3>Aanbeveling externe stakeholder</h3>
          <p>"Thijs heeft alles op orde..."</p>
          <p>"Thijs legt makkelijk contact..."</p>
          <p><strong>Lisa van Zuilen</strong></p>
        </section>
      </section>
    </section>
  </article>

  <section class="reacties-layout">
    <section class="reactie-formulier-sectie">
      <h2>Laat een reactie achter</h2>

      <form action="/genomineerden/{{ nominee.id }}" method="POST" class="reactie-formulier" novalidate>
        <label for="naam">Naam</label>
        <input type="text" id="naam" name="naam" required>
        <small class="foutmelding" id="naam-fout">Vul je naam in.</small>

        <label for="bericht">Bericht</label>
        <textarea id="bericht" name="bericht" rows="6" required></textarea>
        <small class="foutmelding" id="bericht-fout">Vul eerst een bericht in.</small>

        <button type="submit" class="knop-cta reactie-knop">
          <span class="knop-tekst">Verstuur</span>

          <!-- 🔹 LOKALE ICON → GEWOON IMG -->
          <img
            src="/style/assets/sublogo.png"
            alt=""
            class="knop-logo"
            width="20"
            height="20">
        </button>

        <p class="success-melding" id="success-melding">
          Reactie succesvol geplaatst!
        </p>
      </form>
    </section>

    <section class="reacties-sectie">
      <h2>
        {% assign aantal = reacties | size %}
        {% if aantal == 0 %}
          Wees de eerste die reageert
        {% elsif aantal == 1 %}
          1 reactie
        {% else %}
          {{ aantal }} reacties
        {% endif %}
      </h2>

      {% if reacties and reacties.length > 0 %}
        {% assign gesorteerde_reacties = reacties | sort: "date_created" | reverse %}

        <ul class="reacties-lijst">
          {% for reactie in gesorteerde_reacties %}
            <li class="reactie-kaart" id="reactie-{{ reactie.id }}">
              <article class="reactie-inhoud">
                <header class="reactie-header">
                  <p class="reactie-naam">
                    {% if reactie.name == blank or reactie.name == "test" %}
                      Onbekend
                    {% else %}
                      {{ reactie.name }}
                    {% endif %}
                  </p>

                  {% if reactie.date_created %}
                    <p class="reactie-datum">
                      <time datetime="{{ reactie.date_created }}">
                        {{ reactie.date_created | date: "%-d %B %Y" }}
                      </time>
                    </p>
                  {% endif %}
                </header>

                <p class="reactie-bericht">{{ reactie.comment }}</p>

                <form action="/reacties/{{ reactie.id }}/verwijderen" method="POST" class="reactie-verwijder-formulier">
                  <input type="hidden" name="nomineeId" value="{{ nominee.id }}">
                  <button type="submit" class="verwijder-knop">Verwijderen</button>
                </form>
              </article>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p>Er zijn nog geen reacties geplaatst.</p>
      {% endif %}
    </section>
  </section>
</main>

{% render 'partials/foot.liquid' %}